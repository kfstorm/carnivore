#!/usr/bin/env bash

set -euo pipefail

if [[ ${1:-} == "--help" || ${1:-} == "-h" ]]; then
  cat <<'EOF'
Usage: carnivore-fetch URL [OPTIONS]

Fetch readable web content with Carnivore's Dockerized browser pipeline.

Options:
  --format markdown|html|full_html  Extracted content format. Default: markdown.
  --output raw|json                 CLI output mode. Default: raw.
  --resource-mode omit|link|embed    Resource output mode for Markdown/HTML. Default: omit.
                                      omit: remove images/media; link: keep original links; embed: inline resources.
  --verbose                         Print progress logs to stderr. Default: quiet unless an error occurs.
  -h, --help                        Show this help message. Default: not shown.

Environment:
  CARNIVORE_CACHE=0                 Disable cache. Cache is enabled by default.
  CARNIVORE_CACHE_VOLUME=NAME       Docker cache volume. Default: carnivore-cache.
  CARNIVORE_IMAGE=IMAGE             Override the Docker image. Default: official Carnivore image.
  CARNIVORE_PULL=0|1                Control Docker image pulls. Default: pull at most once per day.
  CARNIVORE_STATE_DIR=DIR           State directory for pull timestamps. Default: XDG state directory.
  CARNIVORE_DOCKER_ARGS=ARGS        Extra docker run arguments. Default: none.
  CARNIVORE_RESOURCE_MODE=MODE      Same as --resource-mode. Values: omit, link, embed.
  CARNIVORE_ZENROWS_API_KEY         Pass Zenrows API key. Default: unset.
  CARNIVORE_ZENROWS_PREMIUM_PROXIES Pass Zenrows premium proxy flag. Default: unset.
  CARNIVORE_ZENROWS_JS_RENDERING    Pass Zenrows JS rendering flag. Default: unset.
  CARNIVORE_OXYLABS_USER            Pass OxyLabs credentials. Default: unset.
  CARNIVORE_OXYLABS_JS_RENDERING    Pass OxyLabs JS rendering flag. Default: unset.
EOF
  exit 0
fi

if ! command -v docker > /dev/null; then
  echo "Docker is required to run carnivore-fetch." >&2
  exit 1
fi

image=${CARNIVORE_IMAGE:-ghcr.io/kfstorm/carnivore:latest}
cache_volume=${CARNIVORE_CACHE_VOLUME:-carnivore-cache}
state_dir=${CARNIVORE_STATE_DIR:-${XDG_STATE_HOME:-${HOME}/.local/state}/carnivore-fetch}
image_state_name=${image//[^[:alnum:]._-]/_}
pull_stamp="${state_dir}/pull-${image_state_name}.stamp"

pull_image() {
  pull_output=$(mktemp)
  if docker pull "${image}" > "${pull_output}" 2>&1; then
    rm -f "${pull_output}"
    return 0
  else
    pull_status=$?
    cat "${pull_output}" >&2
    rm -f "${pull_output}"
    return "${pull_status}"
  fi
}

update_pull_stamp() {
  mkdir -p "${state_dir}"
  printf '%s\n' "${1:-$(date +%s)}" > "${pull_stamp}"
}

pull_mode=${CARNIVORE_PULL:-daily}
if [[ ${pull_mode} == "1" ]]; then
  pull_image
  update_pull_stamp
elif [[ ${pull_mode} != "0" ]]; then
  now=$(date +%s)
  last_pull=0

  if [[ -r ${pull_stamp} ]]; then
    read -r last_pull < "${pull_stamp}" || true
  fi

  if ! [[ ${last_pull} =~ ^[0-9]+$ ]]; then
    last_pull=0
  fi

  if (( now < last_pull || now - last_pull >= 86400 )); then
    pull_image
    update_pull_stamp "${now}"
  fi
fi

docker_args=(
  --rm
  -e CARNIVORE_APPLICATION=fetch
  -e CARNIVORE_OUTPUT_FORMATS=markdown
  -e CARNIVORE_OUTPUT_DIR=/tmp/carnivore
)

if [[ ${CARNIVORE_CACHE:-} == "0" ]]; then
  docker_args+=(
    -e CARNIVORE_CACHE=0
  )
else
  docker_args+=(
    -v "${cache_volume}:/cache"
    -e CARNIVORE_CACHE_DIR=/cache
  )
fi

for env_name in \
  CARNIVORE_ZENROWS_API_KEY \
  CARNIVORE_ZENROWS_PREMIUM_PROXIES \
  CARNIVORE_ZENROWS_JS_RENDERING \
  CARNIVORE_RESOURCE_MODE \
  CARNIVORE_OXYLABS_USER \
  CARNIVORE_OXYLABS_JS_RENDERING; do
  if [[ -n ${!env_name:-} ]]; then
    docker_args+=(-e "${env_name}")
  fi
done

if [[ -n ${CARNIVORE_DOCKER_ARGS:-} ]]; then
  # shellcheck disable=SC2206
  extra_docker_args=(${CARNIVORE_DOCKER_ARGS})
  docker_args+=("${extra_docker_args[@]}")
fi

docker run "${docker_args[@]}" "${image}" "$@"
